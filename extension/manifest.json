{
  "manifest_version": 3,
  "name": "Anime Tracker",
  "version": "1.0",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "http://localhost:5000/*",
    "https://*/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  }
}